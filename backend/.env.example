# =================================
# Home Designer Backend Configuration
# =================================
# Copy this file to .env and configure the values for your environment.
# The backend uses dotenv to load these variables on startup.

# ---------------------------------
# Server Configuration
# ---------------------------------

# PORT (optional)
# The port number on which the backend server will listen.
# Default: 5000
# Valid values: Any available port number (1024-65535 recommended)
PORT=5000

# ---------------------------------
# Security Configuration
# ---------------------------------

# ENCRYPTION_KEY (optional, but STRONGLY RECOMMENDED for production)
# A 32-character string used for AES-256 encryption of API keys stored in the database.
# The application stores AI service API keys (TRELLIS, etc.) in the SQLite database.
# These keys are encrypted at rest using this encryption key.
#
# IMPORTANT SECURITY NOTES:
# - If not set, a default key is used (NOT SECURE for production)
# - Must be EXACTLY 32 characters long for AES-256 encryption
# - Generate a secure random key: `openssl rand -base64 32 | cut -c1-32`
# - Keep this key SECRET and do not commit it to version control
# - If you change this key, previously encrypted API keys cannot be decrypted
#
# Default: 'home-designer-default-key-32ch' (INSECURE - for development only)
# Valid values: Any 32-character string
ENCRYPTION_KEY=your-secure-32-character-key-here

# ---------------------------------
# Additional Notes
# ---------------------------------
#
# DATABASE:
# The SQLite database is automatically created at backend/database.db
# No configuration needed - it's managed by the application.
#
# AI API KEYS:
# AI service API keys (TRELLIS, etc.) are NOT stored in environment variables.
# Instead, users configure them through the application's Settings UI.
# These keys are encrypted using ENCRYPTION_KEY and stored in the database.
#
# FRONTEND:
# The frontend (Vite/React) does not use environment variables.
# All configuration is done through the backend API and settings UI.
