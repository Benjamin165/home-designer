.playwright-cli/
.playwright/

# Test/debug scripts (prevent development artifacts)
test-*.js
test-*.mjs
test-*.sh
check-*.js
check-*.mjs
debug-*.js
verify-*.js
setup-test-*.js
create-test-*.js
dump-*.js
simulate-*.js
run-*.js

# Backend test scripts
backend/test-*.js
backend/check-*.js
backend/verify-*.js
backend/debug-*.js

# Screenshot artifacts (root-level only)
/*.png
/*.jpg
/*.jpeg

# Session documentation and progress files
SESSION-*.md
SESSION-*.txt
FEATURE-*-*.md
INITIALIZATION_COMPLETE.md
PROJECT-COMPLETE-*.md
claude-progress.txt
CLAUDE.md

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist/
build/
.vite/
*.local

# Database files
*.db
*.db-shm
*.db-wal
database.db*

# Feature tracking database (managed by AutoForge)
features.db
features.db-*

# Environment variables
.env
.env.local
.env.production
.env.development

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log

# OS files
Thumbs.db
.DS_Store

# Temporary files
tmp/
temp/
*.tmp

# User-generated assets (keep structure, ignore files)
assets/models/*
assets/textures/*
assets/thumbnails/*
!assets/models/.gitkeep
!assets/textures/.gitkeep
!assets/thumbnails/.gitkeep

# Test coverage
coverage/
.nyc_output/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Production
/build
/dist
